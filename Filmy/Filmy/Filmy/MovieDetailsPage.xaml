<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Filmy.MovieDetailsPage"
             Title="Movie Details">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">
            <Label 
                x:Name="TitleLabel"
                FontSize="24" 
                FontAttributes="Bold"/>

            <Image 
                x:Name="PosterImage"
                HeightRequest="300"
                Aspect="AspectFit"/>

            <StackLayout Spacing="5">
                <Label 
                    Text="Description" 
                    FontSize="16" 
                    FontAttributes="Bold"/>
                <Label 
                    x:Name="OverviewLabel"
                    FontSize="14"
                    LineBreakMode="WordWrap"/>
            </StackLayout>

            <StackLayout Spacing="5">
                <Label 
                    Text="Release Date" 
                    FontSize="16" 
                    FontAttributes="Bold"/>
                <Label 
                    x:Name="ReleaseDateLabel"
                    FontSize="14"/>
            </StackLayout>

            <StackLayout Spacing="5">
                <Label 
                    Text="TMDB Rating" 
                    FontSize="16" 
                    FontAttributes="Bold"/>
                <Label 
                    x:Name="RatingLabel"
                    FontSize="14"/>
            </StackLayout>

            <StackLayout Spacing="10">
                <Label 
                    Text="Your Rating" 
                    FontSize="16" 
                    FontAttributes="Bold"/>
                <Picker 
                    x:Name="UserRatingPicker"
                    Title="Rate this movie"
                    SelectedIndexChanged="OnRatingChanged"/>
            </StackLayout>

            <Button 
                x:Name="FavoriteButton"
                Clicked="OnFavoriteClicked"
                Padding="10"/>

            <Button 
                Text="Back" 
                Clicked="OnBackClicked"
                Padding="10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
